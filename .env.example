# Runtime environment name used for framework/runtime behavior.
NODE_ENV=development

# HTTP port the Fastify API listens on locally and in deployment.
PORT=8080

# Prefix mounted in front of versioned API routes such as /meta.
API_PREFIX=/api/v1
CORS_ORIGIN=http://localhost:3000

# Reinsurance capital facility
# Note: "file:./dev.db" is resolved relative to prisma/schema.prisma, i.e. it
# actually creates prisma/dev.db, not a dev.db at the repo root.
DATABASE_URL="file:./dev.db"
MONITOR_INTERVAL_MINUTES=30
ENABLE_FACILITY_MONITOR=true
REINSURER_CLIENT_MODE=stub
ONCHAIN_CLIENT_MODE=stub
DRAWDOWN_REQUEST_PCT=0.1
# REINSURER_API_URL=
# REINSURER_API_KEY=

# STELLAR_NETWORK=testnet
# SOROBAN_RPC_URL=
# SOROBAN_POOL_MANAGER_CONTRACT_ID=

# Multi-party invoice verification
INVOICE_VERIFICATION_TIMEOUT_DAYS=7
INVOICE_TIMEOUT_CHECK_INTERVAL_MINUTES=60
ENABLE_INVOICE_TIMEOUT_MONITOR=true
